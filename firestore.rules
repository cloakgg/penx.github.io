rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.creatorId == request.auth.uid;
    }

    function isValidScript(data) {
      return data.creatorId is string && data.creatorId.size() <= 128
        && data.luaCode is string && data.luaCode.size() <= 1000000
        && data.codeId is string && data.codeId.size() <= 64
        && data.views is number
        && data.createdAt == request.time
        && data.title is string && data.title.size() <= 256;
    }

    match /scripts/{scriptId} {
      // Public access to fetch a script
      allow get: if true;
      
      // Allow listing scripts created by the same device identifier
      allow list: if resource.data.creatorId is string;

      // Allow creating scripts with a persistent device identifier
      allow create: if incoming().creatorId is string
        && incoming().createdAt == request.time
        && incoming().views == 0
        && isValidScript(incoming());

      // Allow updates to views or titles if creatorId matches
      allow update: if existing().creatorId == incoming().creatorId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title']) ||
          incoming().diff(existing()).affectedKeys().hasOnly(['views'])
        );
        
      allow delete: if false; // Prevention of accidental loss
    }
  }
}
